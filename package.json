{
  "name": "xf-cmpt-lib",
  "private": false,
  "version": "0.3.8",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/cmpt-lib-ts.umd.js",
  "module": "./dist/cmpt-lib-ts.es.js",
  "exports": {
    ".": {
      "import": "./dist/cmpt-lib-ts.es.js",
      "require": "./dist/cmpt-lib-ts.umd.js"
    },
    "./dist/cmpt-lib-ts.css": {
      "import": "./dist/cmpt-lib-ts.css",
      "require": "./dist/cmpt-lib-ts.css"
    }
  },
  "types": "./dist/main.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/xfvelocity/xf-cmpt-lib"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "publish:package": "npm install && npm run build && npm publish",
    "test:unit": "vitest",
    "test:unit:coverage": "vitest --coverage",
    "cy:open": "cypress open",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore"
  },
  "dependencies": {
    "@vueuse/core": "^10.1.2",
    "vue": "^3.3.4",
    "vue-inline-svg": "^3.1.2"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.3.0",
    "@types/jsdom": "^21.1.1",
    "@types/node": "^20.2.5",
    "@vitejs/plugin-vue": "^4.2.3",
    "@vitest/coverage-c8": "^0.31.1",
    "@vue/eslint-config-prettier": "^7.1.0",
    "@vue/eslint-config-typescript": "^11.0.3",
    "@vue/test-utils": "^2.3.2",
    "@vue/tsconfig": "^0.4.0",
    "cypress": "^12.13.0",
    "eslint": "^8.41.0",
    "eslint-plugin-cypress": "^2.13.3",
    "eslint-plugin-vue": "^9.14.1",
    "jsdom": "^22.1.0",
    "npm-run-all": "^4.1.5",
    "path": "^0.12.7",
    "prettier": "^2.8.8",
    "rollup": "^3.23.0",
    "rollup-plugin-typescript2": "^0.34.1",
    "sass": "^1.62.1",
    "start-server-and-test": "^2.0.0",
    "tslib": "^2.5.2",
    "typescript": "^5.0.4",
    "vite": "^4.3.9",
    "vite-plugin-dts": "^2.3.0",
    "vitest": "^0.31.1",
    "vue-tsc": "^1.6.5"
  }
}
