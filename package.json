{
  "name": "xf-cmpt-lib",
  "private": false,
  "version": "0.0.11",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/cmpt-lib-ts.umd.js",
  "module": "./dist/cmpt-lib-ts.es.js",
  "exports": {
    ".": {
      "import": "./dist/cmpt-lib-ts.es.js",
      "require": "./dist/cmpt-lib-ts.umd.js"
    },
    "./dist/cmpt-lib-ts.css": {
      "import": "./dist/cmpt-lib-ts.css",
      "require": "./dist/cmpt-lib-ts.css"
    }
  },
  "types": "./dist/main.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/xfvelocity/xf-cmpt-lib"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "publish:package": "npm run build && npm publish",
    "test:unit": "vitest",
    "test:unit:coverage": "vitest --coverage",
    "cy:open": "cypress open",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore"
  },
  "dependencies": {
    "vue": "^3.2.45",
    "vue-inline-svg": "^3.1.2"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.2.0",
    "@types/jsdom": "^20.0.1",
    "@types/node": "^18.14.1",
    "@vitejs/plugin-vue": "^4.0.0",
    "@vitest/coverage-c8": "^0.28.5",
    "@vue/eslint-config-prettier": "^7.1.0",
    "@vue/eslint-config-typescript": "^11.0.2",
    "@vue/test-utils": "^2.3.0",
    "@vue/tsconfig": "^0.1.3",
    "cypress": "^12.7.0",
    "eslint": "^8.35.0",
    "eslint-plugin-cypress": "^2.12.1",
    "eslint-plugin-vue": "^9.9.0",
    "jsdom": "^20.0.3",
    "npm-run-all": "^4.1.5",
    "path": "^0.12.7",
    "prettier": "^2.8.4",
    "rollup": "^3.17.3",
    "rollup-plugin-typescript2": "^0.34.1",
    "sass": "^1.58.3",
    "start-server-and-test": "^1.15.4",
    "tslib": "^2.5.0",
    "typescript": "~4.7.4",
    "vite": "^4.1.4",
    "vite-plugin-dts": "^2.0.2",
    "vitest": "^0.25.8",
    "vue-tsc": "^1.2.0"
  }
}
